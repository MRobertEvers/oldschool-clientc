# Copy to .env and adjust paths. Paths are relative to the repository root unless absolute.

# Directory containing Lua game scripts
SCRIPTS_DIR=src/osrs/scripts

# Directory containing cullmap .bin files
CULLMAPS_DIR=src/osrs/revconfig/configs/cullmaps

# Directory containing the game cache
CACHE_DIR=cache254

# Build output directory (where sdl2.exe / sdl2 lives)
BUILD_DIR=build-mingw

# CMake build type when package_build configures before `cmake --build` (Release = optimized).
BUILD_TYPE=Release

# Output zip file path (relative to repo root unless absolute)
PACKAGE_OUTPUT=package_build.zip

# (Win32 only) Path to SDL2.dll to bundle alongside the executable.
# Leave empty or unset to skip. Typical MinGW location shown.
SDL2_DLL_PATH=C:/msys64/mingw64/bin/SDL2.dll

# (Win32 only) Path to libwinpthread-1.dll (MinGW runtime dependency).
LIBWINPTHREAD_DLL_PATH=C:/msys64/mingw64/bin/libwinpthread-1.dll

# Optional extra args after `cmake --build BUILD_DIR --` (e.g. VERBOSE=1 for Makefile generators).
COMPILE_FLAGS=
