# Flags must be understood by the same Clang that runs clangd (e.g. Apple Clang on
# macOS). GCC-only options (-ftree-vectorizer-*, -fopt-info-*) break every TU and
# can crash or restart clangd.
CompileFlags:
  CompilationDatabase: build/
  Add:
    - -march=native
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_WINSOCK_DEPRECATED_NO_WARNINGS
    - -D_WIN32_WINNT=0x0A00
    - -DUNICODE
    - -D_UNICODE
    - -O3
    - -ffast-math
  Remove:
    - -W*
    - -w
    - /W3
    - /W4

Diagnostics:
  ClangTidy:
    Add:
      - readability-*
      - performance-*
      - modernize-*
    Remove:
      - readability-magic-numbers
      - readability-uppercase-literal-suffix
  UnusedIncludes: Strict
  MissingIncludes: Strict

Index:
  Background: Build
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
