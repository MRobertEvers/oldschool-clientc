# Role-specific env templates (copy each to the matching filename next to its script):
#
#   tools/ci/build_host/.env.build_host.example  ->  tools/ci/build_host/.env.build_host
#   tools/ci/runner/.env.xp_runner.example      ->  tools/ci/runner/.env.xp_runner
#   tools/ci/client/.env.trigger.example        ->  tools/ci/client/.env.trigger
#
# Run:
#   python3 tools/ci/build_host/build_host.py
#   python  tools/ci/runner/xp_listener.py
#   python3 tools/ci/client/trigger_build.py
