# Copy to .env.xp_runner in this directory (not committed). LAN-only; no auth.
# Used only by: xp_listener.py (Python 3.2+ on Windows XP)

# Build host HTTP base (no trailing slash)
BUILD_HOST_BASE_URL=http://192.168.4.1:8765

# Stable id for this machine (saved in results/<git_hash>/<LISTENER_ID>.png)
LISTENER_ID=xp1

# Address the notify HTTP server binds (0.0.0.0 = all interfaces)
NOTIFY_HOST=0.0.0.0
NOTIFY_PORT=8777

# LAN IP or hostname the build host must POST to (not 0.0.0.0)
NOTIFY_PUBLIC_HOST=192.168.4.2

# POST /v1/ping interval (seconds)
HEARTBEAT_INTERVAL_SEC=45

# Passed to run.bat as first argument; subprocess killed after this many seconds
RUN_TIMEOUT_SEC=300

# Log file created in extract dir and uploaded as artifact=log
LOG_FILE_NAME=ci_runner.log
