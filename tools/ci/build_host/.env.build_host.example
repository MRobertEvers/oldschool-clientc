# Copy to .env.build_host in this directory (not committed). LAN-only; no auth.
# Used only by: build_host.py

LISTEN_HOST=0.0.0.0
LISTEN_PORT=8765

# Git checkout + build run here (repo root)
REPO_ROOT=

# Artifact roots (defaults: tools/ci/build_host/artifacts and tools/ci/build_host/results)
ARTIFACTS_ROOT=
RESULTS_ROOT=

# URL XP runners use to reach this host (set LAN IP when LISTEN_HOST is 0.0.0.0)
BUILD_HOST_PUBLIC_BASE=http://192.168.4.1:8765

# Drop subscribers after this many seconds without a successful ping
SUBSCRIBER_TTL_SEC=180

# Windows default: tools/ci/build_host/build_winxp_package.sh (see .cursor/plans/winxp_sse2_package_build_5c026799.plan.md)
# Quick smoke: tools/ci/build_host/build_stub.bat
BUILD_STUB_CMD=

# i686 MinGW "mingw32" root (bin/gcc.exe, bin/SDL2.dll, bin/libwinpthread-1.dll). Required for default Win build.
MINGW_I686=

# Optional: bash.exe if not on PATH (Git Bash / MSYS2)
BASH_EXE=

# Optional: python for package_build.py inside build_winxp_package.sh (default: python)
PYTHON=
